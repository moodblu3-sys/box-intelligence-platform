KNOWLEDGE_DESK_ONYX_MODE=mock
KNOWLEDGE_DESK_PORT=8787

# Real Onyx mode. Use the browser URL exposed by this Docker stack.
ONYX_BASE_URL=http://localhost:3100
ONYX_API_KEY=
ONYX_API_TIMEOUT_MS=60000

# Teams Bot intent classification. Use hybrid to call Onyx/LLM when available,
# with local rules as a fallback.
KNOWLEDGE_DESK_INTENT_MODE=hybrid
KNOWLEDGE_DESK_INTENT_TIMEOUT_MS=8000

# Jira escalation demo
JIRA_BASE_URL=https://moodblu3.atlassian.net
JIRA_EMAIL=moodblu3@gmail.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=CIH
JIRA_ISSUE_TYPE=Task

# Keep true while testing. Set to false only when you want to create a real Jira issue.
JIRA_DRY_RUN=true

# Teams Bot demo
# Use "http" for local smoke tests. Use "connector" when Azure Bot Service calls this API.
TEAMS_BOT_REPLY_MODE=http
MICROSOFT_APP_TYPE=SingleTenant
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TENANT_ID=
