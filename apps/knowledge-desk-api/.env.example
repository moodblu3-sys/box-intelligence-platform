# Real Onyx mode. Use the frontend URL so local calls follow the same route as the app.
ONYX_BASE_URL=http://localhost:3000
ONYX_API_KEY=
ONYX_API_TIMEOUT_MS=60000

# Jira escalation demo
JIRA_BASE_URL=https://moodblu3.atlassian.net
JIRA_EMAIL=moodblu3@gmail.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=CIH
JIRA_ISSUE_TYPE=Task

# Keep true while testing. Set to false only when you want to create a real Jira issue.
JIRA_DRY_RUN=true
